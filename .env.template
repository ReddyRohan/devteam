# ============================================================
# devteam .env — copy this to .env and fill in every value
# NEVER commit .env — it is in .gitignore
# ============================================================

# --- Model proxy (LiteLLM) ---
# LITELLM_MODEL must match a model ID from http://localhost:4000/v1/models
LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_MODEL=claude-sonnet-4-5
LITELLM_API_KEY=placeholder

# --- Discord bot tokens (one per agent) ---
# Create bots at https://discord.com/developers/applications
# Enable "Message Content Intent" for each bot
DISCORD_TOKEN_ORACLE=
DISCORD_TOKEN_DEV=
DISCORD_TOKEN_QUINN=
DISCORD_TOKEN_ARJUN=
DISCORD_TOKEN_PRIYA=
DISCORD_TOKEN_LEX=
DISCORD_TOKEN_DEX=

# --- Discord server ---
# Enable Developer Mode in Discord settings to copy IDs
# Right-click server name → Copy Server ID
DISCORD_GUILD_ID=
# Right-click each channel → Copy Channel ID
DISCORD_CHANNEL_TASKS=
DISCORD_CHANNEL_GENERAL=
DISCORD_CHANNEL_DEVELOPMENT=
DISCORD_CHANNEL_QA=
DISCORD_CHANNEL_ARCHITECTURE=
DISCORD_CHANNEL_DEVOPS=
DISCORD_CHANNEL_DATA=
DISCORD_CHANNEL_PRODUCT=
DISCORD_CHANNEL_OVERSIGHT=

# --- Azure DevOps (for Dev agent) ---
# Create PAT at https://dev.azure.com/<org>/_usersSettings/tokens
# Required scopes: Project+Team (R/W), Code (R/W), Work Items (R/W)
AZDO_PAT=
AZDO_ORG_URL=https://dev.azure.com/<your-org>

# --- Jira (optional) ---
# Create API token at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://<your-org>.atlassian.net
JIRA_API_TOKEN=
JIRA_EMAIL=

# --- GitHub (optional, for Dev agent git operations) ---
GITHUB_PERSONAL_TOKEN=
GITHUB_WORK_TOKEN=

# --- Azure OpenAI (optional, for Pi-hosted agents) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=